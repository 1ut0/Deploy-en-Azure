        <button class="btn-secondary inline-flex items-center gap-2 px-6 py-3 rounded-lg font-syne font-semibold text-sm cursor-pointer transition-all duration-200 bg-surface2 text-muted border border-[rgba(0,120,212,0.25)]" onclick="goTo('step2')">← Paso anterior</button>
        <button class="btn-primary inline-flex items-center gap-2 px-6 py-3 rounded-lg font-syne font-semibold text-sm cursor-pointer transition-all duration-200 bg-azure text-white border-none" onclick="goTo('step4')">Paso 3: Crear recurso Azure →</button>
    </div>
 --></section>