<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Proyecto Astro & Vite</title>
    
	<style>
	html { scroll-behavior: smooth; }

    /* Grid background */
    body::before {
		content: '';
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(0,120,212,0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(0,120,212,0.04) 1px, transparent 1px);
		background-size: 40px 40px;
		pointer-events: none;
		z-index: 0;
    }

    /* Hero radial glow */
    .hero-glow::before {
		content: '';
		position: absolute;
		top: -80px; right: -80px;
		width: 500px; height: 500px;
		background: radial-gradient(circle, rgba(0,120,212,0.12) 0%, transparent 70%);
		pointer-events: none;
    }

    /* Dot pulse in hero tag */
    .dot-pulse::before {
		content: '';
		display: inline-block;
		width: 6px; height: 6px;
		border-radius: 50%;
		background: #00d4aa;
		margin-right: 6px;
		animation: pulse2 2s ease-in-out infinite;
		vertical-align: middle;
    }

    /* Card list arrow */
    .card-list li::before {
		content: '→';
		color: #50b0f0;
		flex-shrink: 0;
		margin-top: 1px;
    }

    /* Section visibility */
    .step-section { display: none; animation: fadeIn 0.35s ease; }
    .step-section.active { display: block; }
    #intro { display: block !important; }

    /* Nav states */
    .nav-item:hover          { background: rgba(0,120,212,0.10); color: #50b0f0; }
    .nav-item.active         { background: rgba(0,120,212,0.15); color: #50b0f0; font-weight: 500; }
    .nav-item:hover .step-num,
    .nav-item.active .step-num { background: rgba(0,120,212,0.3); border-color: #0078d4; color: #50b0f0; }
    .nav-item.done .step-num   { background: rgba(0,212,170,0.2); border-color: #00d4aa; color: #00d4aa; }

    /* Checklist states */
    .check-item:hover          { border-color: #0078d4; }
    .check-item.checked        { background: rgba(0,212,170,0.06); border-color: rgba(0,212,170,0.3); }
    .check-item.checked .checkbox { background: #00d4aa; border-color: #00d4aa; color: #060c14; }
    .check-item.checked span   { color: #e8f0f8; }

    /* Copy button states */
    .copy-btn:hover  { border-color: #0078d4; color: #50b0f0; background: rgba(0,120,212,0.1); }
    .copy-btn.copied { border-color: #00d4aa; color: #00d4aa; }

    /* Button hover effects */
    .btn-primary:hover   { background: #50b0f0; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,120,212,0.4); }
    .btn-secondary:hover { color: #e8f0f8; border-color: #0078d4; }

    /* Code syntax colors */
    pre .cmd     { color: #50b0f0; }
    pre .comment { color: #4a6a8a; font-style: italic; }
    pre .str     { color: #00d4aa; }
    pre .kw      { color: #f0a050; }

    /* Scrollbar */
    ::-webkit-scrollbar       { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #0d1825; }
    ::-webkit-scrollbar-thumb { background: rgba(0,120,212,0.3); border-radius: 3px; }

    /* Progress fill transition */
    #progressFill { transition: width 0.5s cubic-bezier(0.4,0,0.2,1); }
</style>
</head>
	<body class="font-sans bg-bg text-[#e8f0f8] min-h-screen text-base leading-[1.7]">
		<slot />
	</body>
</html>
