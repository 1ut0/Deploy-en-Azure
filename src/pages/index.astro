import FirstStep from '../components/firststep.astro';
import Secondstep from '../components/secondstep.astro';
import Threestep from '../components/threestep.astro';
import Fourthstep from '../components/fourthstep.astro';
import Fifthstep from '../components/fifth.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';


---

<Layout>
	<main class="ml-260px relative z-1 max-[900px]:ml-0">
		<Hero />
		<!-- Additional sections for steps will go here -->
		<FirstStep />
		<Secondstep />
		<Threestep />
		<Fourthstep />
		<Fifthstep />
	</main>
</Layout>
